generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empleado {
  id        Int      @id @default(autoincrement())
  nombre    String
  rol       String
  pin       String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  ventasComoVendedor Venta[]        @relation("VentaVendedor")
  ventasComoCobrador Venta[]        @relation("VentaCobrador")
  presupuestos       Presupuesto[]
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Float
  stock     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  itemsVenta       ItemVenta[]
  itemsPresupuesto ItemPresupuesto[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String   @unique
  createdAt DateTime @default(now())
  ventas       Venta[]
  presupuestos Presupuesto[]
}

model Venta {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @default(now())
  total       Float
  estado      String
  formaPago   String?
  fechaCobro  DateTime?
  vendedorId  Int
  vendedor    Empleado  @relation("VentaVendedor", fields: [vendedorId], references: [id])
  cobradorId  Int?
  cobrador    Empleado? @relation("VentaCobrador", fields: [cobradorId], references: [id])
  clienteId   Int?
  cliente     Cliente?  @relation(fields: [clienteId], references: [id])
  items       ItemVenta[]
}

model ItemVenta {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Int
  precio     Float
}

model Presupuesto {
  id           Int      @id @default(autoincrement())
  fecha        DateTime @default(now())
  validoHasta  DateTime
  total        Float
  estado       String   @default("vigente")
  clienteId    Int
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  vendedorId   Int
  vendedor     Empleado @relation(fields: [vendedorId], references: [id])
  items        ItemPresupuesto[]
}

model ItemPresupuesto {
  id             Int          @id @default(autoincrement())
  presupuestoId  Int
  presupuesto    Presupuesto  @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  productoId     Int
  producto       Producto     @relation(fields: [productoId], references: [id])
  cantidad       Int
  precio         Float
}

model CierreCaja {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now())
  ingresos  Float
  egresos   Float
  ventas    Int
  total     Float
}
